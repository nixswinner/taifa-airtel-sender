# Airtel CPaaS - Kong Basic Auth credentials
AIRTEL_USERNAME=your_kong_username
AIRTEL_PASSWORD=your_kong_password

# Business identifiers
AIRTEL_CUSTOMER_ID=your_customer_id
AIRTEL_SENDER_ID=your_sender_id

# Gateway base URL (production)
AIRTEL_BASE_URL=https://www.airtelkenya.com/gateway/v1

# Retry configuration
AIRTEL_MAX_RETRIES=3
AIRTEL_RETRY_DELAY_SECONDS=1.0
AIRTEL_RETRY_BACKOFF_FACTOR=2.0
AIRTEL_REQUEST_TIMEOUT_SECONDS=30

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_MAIN_QUEUE=mq_sms_airtel
RABBITMQ_RETRY_QUEUE=mq_sms_airtel_retry
RABBITMQ_DLQ=mq_sms_airtel_dlq
RABBITMQ_RETRY_EXCHANGE=mq_sms_airtel_retry_exchange

# ── Consumer tuning ───────────────────────────────────────────────────────────
PREFETCH_COUNT=10
WORKER_THREADS=1

# ── Retry / backoff ───────────────────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=10
BASE_RETRY_DELAY_MS=5000
MAX_RETRY_DELAY_MS=300000

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_PORT=8000
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# ── Callback ──────────────────────────────────────────────────────────────────
CALLBACK_TIMEOUT=30
CALLBACK_RETRY_ATTEMPTS=3
CALLBACK_RETRY_DELAY=2
